# API cần lấy dữ liệu
SOURCE_API_URL=https://api.github.com/zen
SOURCE_API_METHOD=GET
SOURCE_API_TIMEOUT=15

# Token hiện tại cho source API (nếu có)
SOURCE_API_ACCESS_TOKEN=
SOURCE_API_AUTH_HEADER=Authorization
SOURCE_API_TOKEN_PREFIX=Bearer

# Cấu hình refresh token khi source API trả 401
TOKEN_URL=
TOKEN_GRANT_TYPE=client_credentials
TOKEN_CLIENT_ID=
TOKEN_CLIENT_SECRET=
TOKEN_SCOPE=
TOKEN_FIELD_NAME=access_token

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:your_bot_token
TELEGRAM_CHAT_ID=123456789
TELEGRAM_PARSE_MODE=HTML

# Flask
PORT=5000
LOG_LEVEL=INFO
